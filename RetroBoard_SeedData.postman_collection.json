            "console.log('🔑 Acme Invite Code:', j.inviteCode);",
            "pm.test('Kayıt başarılı', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@acme.com\",\n  \"password\": \"acme1234\",\n  \"fullName\": \"Ahmet Yılmaz\",\n  \"companyName\": \"Acme Corp\"\n}" },
            "url": { "raw": "{{base}}/auth/register", "host": ["{{base}}"], "path": ["auth","register"] }
