{
  "info": {
    "name": "RetroBoard API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" },
    { "key": "companyInviteCode", "value": "" },
    { "key": "teamId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "boardId", "value": "" },
    { "key": "cardId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register - Şirket Kur (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('companyInviteCode', json.inviteCode);",
                  "  console.log('Token set:', json.token);",
                  "  console.log('Invite Code:', json.inviteCode);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@acme.com\",\n  \"password\": \"123456\",\n  \"fullName\": \"Admin User\",\n  \"companyName\": \"Acme Corp\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Register - Şirkete Katıl (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  console.log('User Token:', json.token);",
                  "  pm.collectionVariables.set('userId', json.companyId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@acme.com\",\n  \"password\": \"123456\",\n  \"fullName\": \"Normal User\",\n  \"inviteCode\": \"{{companyInviteCode}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  if (json.inviteCode) pm.collectionVariables.set('companyInviteCode', json.inviteCode);",
                  "  console.log('Token set:', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@acme.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Teams",
      "item": [
        {
          "name": "Takımları Listele",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/teams", "host": ["{{baseUrl}}"], "path": ["teams"] }
          }
        },
        {
          "name": "Takım Oluştur",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('teamId', json.id);",
                  "console.log('Team ID:', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Backend Team\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/teams", "host": ["{{baseUrl}}"], "path": ["teams"] }
          }
        },
        {
          "name": "Takıma Üye Ekle",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/teams/{{teamId}}/members/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["teams", "{{teamId}}", "members", "{{userId}}"]
            }
          }
        },
        {
          "name": "Takımdan Üye Çıkar",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/teams/{{teamId}}/members/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["teams", "{{teamId}}", "members", "{{userId}}"]
            }
          }
        },
        {
          "name": "Takım Sil",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/teams/{{teamId}}",
              "host": ["{{baseUrl}}"],
              "path": ["teams", "{{teamId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Şirket Kullanıcılarını Listele",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (Array.isArray(json) && json.length > 1) {",
                  "  var nonAdmin = json.find(u => u.role === 'USER');",
                  "  if (nonAdmin) {",
                  "    pm.collectionVariables.set('userId', nonAdmin.id);",
                  "    console.log('userId set to:', nonAdmin.id, nonAdmin.fullName);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] }
          }
        },
        {
          "name": "Kullanıcı Rolü Değiştir (USER → ADMIN)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/role?role=ADMIN",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "role"],
              "query": [{ "key": "role", "value": "ADMIN" }]
            }
          }
        },
        {
          "name": "Kullanıcı Rolü Değiştir (ADMIN → USER)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/role?role=USER",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "role"],
              "query": [{ "key": "role", "value": "USER" }]
            }
          }
        }
      ]
    },
    {
      "name": "Boards",
      "item": [
        {
          "name": "Board Listesi",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/boards", "host": ["{{baseUrl}}"], "path": ["boards"] }
          }
        },
        {
          "name": "Board Oluştur",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('boardId', json.id);",
                  "console.log('Board ID:', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Q2 Sprint 1 Retro\",\n  \"sprintName\": \"Sprint 1\",\n  \"teamId\": {{teamId}}\n}"
            },
            "url": { "raw": "{{baseUrl}}/boards", "host": ["{{baseUrl}}"], "path": ["boards"] }
          }
        },
        {
          "name": "Board Detay",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/boards/{{boardId}}",
              "host": ["{{baseUrl}}"],
              "path": ["boards", "{{boardId}}"]
            }
          }
        },
        {
          "name": "Board Sil",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/boards/{{boardId}}",
              "host": ["{{baseUrl}}"],
              "path": ["boards", "{{boardId}}"]
            }
          }
        },
        {
          "name": "Kart Ekle (WENT_WELL)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('cardId', json.id);",
                  "console.log('Card ID:', json.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Takım iletişimi çok iyiydi\",\n  \"columnType\": \"WENT_WELL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/boards/{{boardId}}/cards",
              "host": ["{{baseUrl}}"],
              "path": ["boards", "{{boardId}}", "cards"]
            }
          }
        },
        {
          "name": "Kart Ekle (TO_IMPROVE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Deployment süreci daha otomatik olmalı\",\n  \"columnType\": \"TO_IMPROVE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/boards/{{boardId}}/cards",
              "host": ["{{baseUrl}}"],
              "path": ["boards", "{{boardId}}", "cards"]
            }
          }
        },
        {
          "name": "Kart Ekle (ACTION_ITEMS)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"CI/CD pipeline kurulacak\",\n  \"columnType\": \"ACTION_ITEMS\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/boards/{{boardId}}/cards",
              "host": ["{{baseUrl}}"],
              "path": ["boards", "{{boardId}}", "cards"]
            }
          }
        },
        {
          "name": "Karta Oy Ver",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/boards/cards/{{cardId}}/vote",
              "host": ["{{baseUrl}}"],
              "path": ["boards", "cards", "{{cardId}}", "vote"]
            }
          }
        },
        {
          "name": "Kart Sil",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/boards/cards/{{cardId}}",
              "host": ["{{baseUrl}}"],
              "path": ["boards", "cards", "{{cardId}}"]
            }
          }
        }
      ]
    }
  ]
}
