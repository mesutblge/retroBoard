{
  "info": {
    "name": "RetroBoard API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mesut@retroboard.com\",\n  \"password\": \"123456\",\n  \"fullName\": \"Mesut Bilge\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "pm.collectionVariables.set('token', res.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mesut@retroboard.com\",\n  \"password\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        }
      ]
    },
    {
      "name": "Boards",
      "item": [
        {
          "name": "Board Oluştur",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/boards",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sprint 1 Retro\",\n  \"sprintName\": \"Sprint 1\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Boardlarımı Getir",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/boards",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards"]
            }
          }
        },
        {
          "name": "Board Detay",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/boards/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards", "1"]
            }
          }
        },
        {
          "name": "Board Sil",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/boards/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Cards",
      "item": [
        {
          "name": "Kart Ekle - Went Well",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/boards/1/cards",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards", "1", "cards"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"CI/CD pipeline çok hızlı\",\n  \"columnType\": \"WENT_WELL\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Kart Ekle - To Improve",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/boards/1/cards",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards", "1", "cards"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Code review süreci uzun\",\n  \"columnType\": \"TO_IMPROVE\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Kart Ekle - Action Items",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/boards/1/cards",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards", "1", "cards"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Haftalık teknik toplantı kur\",\n  \"columnType\": \"ACTION_ITEMS\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Karta Oy Ver",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/boards/cards/1/vote",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards", "cards", "1", "vote"]
            }
          }
        },
        {
          "name": "Kart Sil",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/boards/cards/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "boards", "cards", "1"]
            }
          }
        }
      ]
    }
  ]
}
